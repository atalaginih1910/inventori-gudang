<%- include('../partials/header') %>

<!-- Filters -->
<div class="card border-0 shadow-sm mb-4">
  <div class="card-body py-3">
    <form class="row g-2 align-items-center" method="get" action="/transaksi">
      <div class="col-auto">
        <input type="text" name="cari" class="form-control form-control-sm" placeholder="Cari produk..." value="<%= cari %>" style="width:180px;" />
      </div>
      <div class="col-auto">
        <select name="jenis" class="form-select form-select-sm" style="width:130px;">
          <option value="">Semua Jenis</option>
          <option value="masuk" <%= jenis === 'masuk' ? 'selected' : '' %>>Masuk</option>
          <option value="keluar" <%= jenis === 'keluar' ? 'selected' : '' %>>Keluar</option>
        </select>
      </div>
      <div class="col-auto">
        <input type="date" name="dari" class="form-control form-control-sm" value="<%= dari %>" />
      </div>
      <div class="col-auto">
        <span class="text-secondary small">s/d</span>
      </div>
      <div class="col-auto">
        <input type="date" name="sampai" class="form-control form-control-sm" value="<%= sampai %>" />
      </div>
      <div class="col-auto">
        <button type="submit" class="btn btn-sm btn-outline-secondary"><i class="bi bi-search me-1"></i>Filter</button>
        <a href="/transaksi" class="btn btn-sm btn-outline-danger ms-1"><i class="bi bi-x-lg"></i></a>
      </div>
      <div class="col-auto ms-auto">
        <a href="/transaksi/tambah" class="btn btn-primary btn-sm">
          <i class="bi bi-plus-lg me-1"></i>Catat Transaksi
        </a>
      </div>
    </form>
  </div>
</div>

<!-- Table -->
<div class="card border-0 shadow-sm">
  <div class="card-body p-0">
    <% if (transaksi.length === 0) { %>
      <div class="text-center py-5 text-secondary">
        <i class="bi bi-inbox fs-1 d-block mb-2 text-muted"></i>
        <p class="mb-0">Tidak ada transaksi ditemukan</p>
        <a href="/transaksi/tambah" class="btn btn-sm btn-primary mt-2">Catat Transaksi</a>
      </div>
    <% } else { %>
      <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">
          <thead class="table-light">
            <tr>
              <th>#</th>
              <th>Tanggal</th>
              <th>Produk</th>
              <th>Jenis</th>
              <th>Jumlah</th>
              <th>Stok Sebelum</th>
              <th>Stok Sesudah</th>
              <th>Keterangan</th>
              <th>Aksi</th>
            </tr>
          </thead>
          <tbody>
            <% transaksi.forEach((t, idx) => { %>
              <tr>
                <td class="text-secondary small"><%= idx + 1 %></td>
                <td class="text-nowrap small">
                  <%= new Date(t.tanggal).toLocaleDateString('id-ID', {day:'2-digit', month:'short', year:'numeric'}) %>
                </td>
                <td><strong><%= t.nama_produk %></strong></td>
                <td>
                  <span class="badge <%= t.jenis === 'masuk' ? 'bg-success' : 'bg-danger' %>">
                    <i class="bi <%= t.jenis === 'masuk' ? 'bi-arrow-down' : 'bi-arrow-up' %> me-1"></i>
                    <%= t.jenis === 'masuk' ? 'Masuk' : 'Keluar' %>
                  </span>
                </td>
                <td class="fw-bold"><%= t.jumlah %> <%= t.satuan %></td>
                <td class="text-secondary"><%= t.stok_sebelum != null ? t.stok_sebelum : '-' %></td>
                <td class="text-secondary"><%= t.stok_sesudah != null ? t.stok_sesudah : '-' %></td>
                <td class="text-secondary small"><%= t.keterangan || '-' %></td>
                <td>
                  <form action="/transaksi/<%= t.id %>?_method=DELETE" method="POST"
                    onsubmit="return confirm('Hapus catatan transaksi ini? Stok TIDAK akan dikembalikan.')">
                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Hapus">
                      <i class="bi bi-trash"></i>
                    </button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</div>

<%- include('../partials/footer') %>
