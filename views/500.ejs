<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>500 - Inventori Gudang</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
</head>
<body class="bg-light">
  <div class="d-flex align-items-center justify-content-center" style="min-height:100vh;">
    <div class="text-center">
      <i class="bi bi-bug display-1 text-danger mb-3"></i>
      <h1 class="display-4 fw-bold">500</h1>
      <p class="text-secondary fs-5">Terjadi kesalahan pada server</p>
      <% if (typeof error !== 'undefined' && error) { %>
        <p class="text-danger small"><code><%= error %></code></p>
      <% } %>
      <a href="/" class="btn btn-primary"><i class="bi bi-house me-1"></i>Kembali ke Dashboard</a>
    </div>
  </div>
</body>
</html>
