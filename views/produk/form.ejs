<%- include('../partials/header') %>

<div class="row justify-content-center">
  <div class="col-lg-7">
    <div class="card border-0 shadow-sm">
      <div class="card-header bg-white border-bottom pt-3">
        <h6 class="mb-0 fw-semibold">
          <i class="bi <%= produk ? 'bi-pencil-square' : 'bi-plus-circle' %> me-2 text-primary"></i>
          <%= produk ? 'Edit Produk' : 'Tambah Produk Baru' %>
        </h6>
      </div>
      <div class="card-body">
        <form action="<%= action %>" method="POST">
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label fw-semibold">Nama Produk <span class="text-danger">*</span></label>
              <input type="text" name="nama" class="form-control" required
                value="<%= produk ? produk.nama : '' %>" placeholder="Nama produk" />
            </div>
            <div class="col-md-6">
              <label class="form-label fw-semibold">Kode Produk</label>
              <input type="text" name="kode" class="form-control"
                value="<%= produk ? produk.kode : '' %>" placeholder="Kode unik (opsional)" />
            </div>
            <div class="col-md-6">
              <label class="form-label fw-semibold">Kategori</label>
              <select name="kategori_id" class="form-select">
                <option value="">-- Pilih Kategori --</option>
                <% kategori.forEach(k => { %>
                  <option value="<%= k.id %>" <%= produk && produk.kategori_id === k.id ? 'selected' : '' %>><%= k.nama %></option>
                <% }) %>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label fw-semibold">Satuan</label>
              <input type="text" name="satuan" class="form-control"
                value="<%= produk ? produk.satuan : 'pcs' %>" placeholder="pcs, kg, liter, dll" />
            </div>
            <div class="col-md-4">
              <label class="form-label fw-semibold">Stok Awal <span class="text-danger">*</span></label>
              <input type="number" name="stok" class="form-control" min="0" required
                value="<%= produk ? produk.stok : 0 %>" />
            </div>
            <div class="col-md-4">
              <label class="form-label fw-semibold">Stok Minimum</label>
              <input type="number" name="stok_minimum" class="form-control" min="0"
                value="<%= produk ? produk.stok_minimum : 0 %>" />
              <div class="form-text">Alert jika stok ≤ nilai ini</div>
            </div>
            <div class="col-md-4">
              <label class="form-label fw-semibold">Harga Satuan (Rp)</label>
              <input type="number" name="harga" class="form-control" min="0" step="any"
                value="<%= produk ? produk.harga : 0 %>" />
            </div>
            <div class="col-12">
              <label class="form-label fw-semibold">Deskripsi</label>
              <textarea name="deskripsi" class="form-control" rows="3"
                placeholder="Deskripsi produk (opsional)"><%= produk ? produk.deskripsi : '' %></textarea>
            </div>
          </div>
          <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-primary">
              <i class="bi bi-check-lg me-1"></i><%= produk ? 'Simpan Perubahan' : 'Tambah Produk' %>
            </button>
            <a href="/produk" class="btn btn-outline-secondary">Batal</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
