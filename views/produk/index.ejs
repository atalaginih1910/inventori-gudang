<%- include('../partials/header') %>

<!-- Toolbar -->
<div class="d-flex justify-content-between align-items-center mb-4">
  <form class="d-flex gap-2 flex-wrap" method="get" action="/produk">
    <input type="text" name="cari" class="form-control form-control-sm" placeholder="Cari nama / kode..." value="<%= cari %>" style="width:200px;" />
    <select name="kategori_id" class="form-select form-select-sm" style="width:160px;">
      <option value="">Semua Kategori</option>
      <% kategori.forEach(k => { %>
        <option value="<%= k.id %>" <%= kategori_id == k.id ? 'selected' : '' %>><%= k.nama %></option>
      <% }) %>
    </select>
    <select name="stok_filter" class="form-select form-select-sm" style="width:140px;">
      <option value="">Semua Stok</option>
      <option value="rendah" <%= stok_filter === 'rendah' ? 'selected' : '' %>>Stok Rendah</option>
      <option value="habis" <%= stok_filter === 'habis' ? 'selected' : '' %>>Stok Habis</option>
    </select>
    <button type="submit" class="btn btn-sm btn-outline-secondary"><i class="bi bi-search"></i></button>
    <a href="/produk" class="btn btn-sm btn-outline-danger"><i class="bi bi-x-lg"></i></a>
  </form>
  <a href="/produk/tambah" class="btn btn-primary btn-sm">
    <i class="bi bi-plus-lg me-1"></i>Tambah Produk
  </a>
</div>

<!-- Table -->
<div class="card border-0 shadow-sm">
  <div class="card-body p-0">
    <% if (produk.length === 0) { %>
      <div class="text-center py-5 text-secondary">
        <i class="bi bi-box-seam fs-1 d-block mb-2 text-muted"></i>
        <p class="mb-0">Tidak ada produk ditemukan</p>
        <a href="/produk/tambah" class="btn btn-sm btn-primary mt-2">Tambah Produk</a>
      </div>
    <% } else { %>
      <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">
          <thead class="table-light">
            <tr>
              <th>#</th>
              <th>Kode</th>
              <th>Nama Produk</th>
              <th>Kategori</th>
              <th>Stok</th>
              <th>Min. Stok</th>
              <th>Satuan</th>
              <th>Harga</th>
              <th>Aksi</th>
            </tr>
          </thead>
          <tbody>
            <% produk.forEach((p, idx) => { %>
              <tr>
                <td class="text-secondary small"><%= idx + 1 %></td>
                <td><code><%= p.kode || '-' %></code></td>
                <td>
                  <strong><%= p.nama %></strong>
                  <% if (p.deskripsi) { %>
                    <div class="small text-secondary"><%= p.deskripsi %></div>
                  <% } %>
                </td>
                <td><span class="badge bg-secondary bg-opacity-75"><%= p.nama_kategori %></span></td>
                <td>
                  <span class="fw-bold <%= p.stok === 0 ? 'text-danger' : (p.stok <= p.stok_minimum ? 'text-warning' : 'text-success') %>">
                    <%= p.stok %>
                  </span>
                  <% if (p.stok <= p.stok_minimum && p.stok > 0) { %>
                    <span class="badge bg-warning text-dark ms-1">Rendah</span>
                  <% } else if (p.stok === 0) { %>
                    <span class="badge bg-danger ms-1">Habis</span>
                  <% } %>
                </td>
                <td class="text-secondary"><%= p.stok_minimum %></td>
                <td><%= p.satuan %></td>
                <td>Rp <%= (p.harga || 0).toLocaleString('id-ID') %></td>
                <td>
                  <div class="d-flex gap-1">
                    <a href="/produk/<%= p.id %>/edit" class="btn btn-sm btn-outline-primary" title="Edit">
                      <i class="bi bi-pencil"></i>
                    </a>
                    <a href="/transaksi/tambah?produk_id=<%= p.id %>" class="btn btn-sm btn-outline-success" title="Catat Transaksi">
                      <i class="bi bi-arrow-left-right"></i>
                    </a>
                    <form action="/produk/<%= p.id %>?_method=DELETE" method="POST" onsubmit="return confirm('Hapus produk ini?')">
                      <button type="submit" class="btn btn-sm btn-outline-danger" title="Hapus">
                        <i class="bi bi-trash"></i>
                      </button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</div>

<%- include('../partials/footer') %>
